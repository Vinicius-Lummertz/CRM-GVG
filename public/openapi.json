              }
            }
          }
        }
      }
    },
    "/api/v1/auth/otp/verify": {
      "post": {
        "tags": [
          "Auth V1"
        ],
        "summary": "Valida OTP",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthOtpVerifyBody"
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/refresh": {

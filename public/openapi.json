        ]
      }
    },
    "/api/whatsapp/webhook": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Webhook legado de entrada",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    "/api/v1/providers/whatsapp/webhooks/inbound": {

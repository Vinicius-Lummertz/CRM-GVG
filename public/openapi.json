    },
    "/api/v1/providers/whatsapp/webhooks/status": {
      "post": {
        "tags": [
          "Webhooks"
        ],
        "summary": "Webhook v1 status",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        }
      }
    },
    "/api/leads": {
      "get": {
        "tags": [
          "Legacy"
        ],
        "summary": "Lista leads (legado)",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "temperature",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "attention_required",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ]
      }
    },
    "/api/leads/{leadId}/messages": {
      "get": {
        "tags": [
          "Legacy"
        ],
        "summary": "Mensagens do lead (legado)",
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ]
      }
    },
    "/api/media-proxy": {
      "get": {
        "tags": [
          "Legacy"
        ],
        "summary": "Proxy de mídia",
        "parameters": [
          {
            "name": "url",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uri"
            }
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "AuthOtpRequestBody": {
        "type": "object",
        "required": [
          "phone_e164"
        ],
        "properties": {
          "phone_e164": {
            "type": "string",
            "example": "+5511999999999"
          }
        }
      },
      "AuthOtpVerifyBody": {
        "type": "object",
        "required": [
          "challenge_id",
          "code"
        ],
        "properties": {
          "challenge_id": {
            "type": "string"
          },
          "code": {
            "type": "string"
          }
        }
      },
      "AuthRefreshBody": {
        "type": "object",
        "required": [
          "refresh_token"
        ],
        "properties": {
          "refresh_token": {
            "type": "string"
          }
        }
      },
      "SendConversationMessageBody": {
        "type": "object",
        "required": [
          "body"
        ],
        "properties": {
          "type": {
            "type": "string",
            "default": "text"
          },
          "body": {},
          "template_id": {
            "type": "string"
          },
          "variables": {
            "type": "object",
            "additionalProperties": true
          },
          "mode": {
            "type": "string",
            "default": "real"
          },
          "idempotency_key": {
            "type": "string"
          }
        }
      },
      "UpdateConversationStatusBody": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "UpdateConversationOwnerBody": {
        "type": "object",
        "properties": {
          "owner_id": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "CreateTemplateBody": {
        "type": "object",
        "required": [
          "name",
          "body"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "UpdateTemplateBody": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "variables": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "is_active": {
            "type": "boolean"
          }
        }
      },
      "SendTemplateBody": {
        "type": "object",
        "required": [
          "conversation_id"
        ],
        "properties": {
          "conversation_id": {
            "type": "string"
          },
          "variables": {
            "type": "object",
            "additionalProperties": true
          },
          "mode": {
            "type": "string",
            "default": "real"
          },
          "idempotency_key": {
            "type": "string"
          }
        }
      }
    }
  }
}

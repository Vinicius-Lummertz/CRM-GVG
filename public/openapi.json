{
  "openapi": "3.0.3",
  "info": {
    "title": "CRM-GVG API",
    "version": "1.0.0",
    "description": "Documentação de teste dos endpoints do backend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Ambiente local"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth V1" },
    { "name": "Conversations V1" },
    { "name": "Templates V1" },
    { "name": "Events" },
    { "name": "Webhooks" },
    { "name": "Legacy" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check"
      }
    },
    "/api/v1/auth/otp/request": {
      "post": {
        "tags": ["Auth V1"],
        "summary": "Solicita OTP"
      }
    },
    "/api/v1/auth/otp/verify": {
      "post": {
        "tags": ["Auth V1"],
        "summary": "Valida OTP"
      }
    },
    "/api/v1/auth/refresh": {
      "post": {
        "tags": ["Auth V1"],
        "summary": "Renova token"
      }
    },
    "/api/v1/auth/logout": {
      "post": {
        "tags": ["Auth V1"],
        "summary": "Logout",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": ["Auth V1"],
        "summary": "Usuário atual",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/conversations": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Lista conversas",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/conversations/{conversationId}": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Busca conversa",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/conversations/{conversationId}/messages": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Lista mensagens da conversa",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      },
      "post": {
        "tags": ["Conversations V1"],
        "summary": "Envia mensagem",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/conversations/{conversationId}/status": {
      "patch": {
        "tags": ["Conversations V1"],
        "summary": "Atualiza status da conversa",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/conversations/{conversationId}/owner": {
      "patch": {
        "tags": ["Conversations V1"],
        "summary": "Atualiza owner da conversa",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/conversations/{conversationId}/insights": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Retorna insights da conversa",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "conversationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/messages/{messageId}": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Busca mensagem por id",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "messageId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/operators": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Lista operadores",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/dashboard/metrics": {
      "get": {
        "tags": ["Conversations V1"],
        "summary": "Métricas do dashboard",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/templates": {
      "get": {
        "tags": ["Templates V1"],
        "summary": "Lista templates",
        "security": [{ "bearerAuth": [] }]
      },
      "post": {
        "tags": ["Templates V1"],
        "summary": "Cria template",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/v1/templates/{templateId}": {
      "patch": {
        "tags": ["Templates V1"],
        "summary": "Atualiza template",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/v1/templates/{templateId}/send": {
      "post": {
        "tags": ["Templates V1"],
        "summary": "Dispara template",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "templateId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/events": {
      "get": {
        "tags": ["Events"],
        "summary": "SSE legado"
      }
    },
    "/api/v1/events": {
      "get": {
        "tags": ["Events"],
        "summary": "SSE v1",
        "security": [{ "bearerAuth": [] }]
      }
    },
    "/api/whatsapp/webhook": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Webhook legado de entrada"
      }
    },
    "/api/v1/providers/whatsapp/webhooks/inbound": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Webhook v1 inbound"
      }
    },
    "/api/v1/providers/whatsapp/webhooks/status": {
      "post": {
        "tags": ["Webhooks"],
        "summary": "Webhook v1 status"
      }
    },
    "/api/leads": {
      "get": {
        "tags": ["Legacy"],
        "summary": "Lista leads (legado)"
      }
    },
    "/api/leads/{leadId}/messages": {
      "get": {
        "tags": ["Legacy"],
        "summary": "Mensagens do lead (legado)",
        "parameters": [
          {
            "name": "leadId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ]
      }
    },
    "/api/media-proxy": {
      "get": {
        "tags": ["Legacy"],
        "summary": "Proxy de mídia"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}

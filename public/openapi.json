              "type": "string"
            }
          },
          {
            "name": "is_active",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ]
      },
      "post": {
        "tags": [
          "Templates V1"
        ],
        "summary": "Cria template",
        "security": [
          {
            "bearerAuth": []

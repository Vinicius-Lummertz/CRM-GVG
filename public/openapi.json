{
  "openapi": "3.0.3",
  "info": {
    "title": "CRM-GVG API",
    "version": "1.0.0",
    "description": "Documentação de teste dos endpoints do backend."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Ambiente local"
    }
